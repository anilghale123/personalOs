# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit real secrets.

# MongoDB connection string (MongoDB Atlas recommended).
# If your network blocks DNS SRV lookups, use the standard (non-SRV)
# mongodb:// string from Atlas → Connect → Drivers instead of mongodb+srv://.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/

# NextAuth v5 — generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-strong-random-secret
NEXTAUTH_SECRET=replace-with-a-strong-random-secret
NEXTAUTH_URL=http://localhost:3000

# Groq AI — get a key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google OAuth — create credentials at https://console.cloud.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Protects the NEPSE cron route — generate with: openssl rand -hex 32
CRON_SECRET=replace-with-a-strong-random-hex
